{
  "name": "expressjs-boilerplate",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "rimraf build && tsc",
    "start": "node build/server.js",
    "test": "clear && mocha -r ts-node/register __test__/**/*.specs.ts --exit",
    "db:migrate": "node ./node_modules/knex/bin/cli.js migrate:latest --knexfile ./knexfile.ts",
    "db:seed": "node ./node_modules/knex/bin/cli.js seed:run --knexfile ./knexfile.ts",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "make:migration": "node ./node_modules/knex/bin/cli.js migrate:make",
    "make:seed": "node ./node_modules/knex/bin/cli.js seed:make"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-useragent": "^2.1.0",
    "google-libphonenumber": "^3.2.44",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "mysql2": "^3.19.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/chai": "^5.2.3",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-useragent": "^1.0.5",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
