{
  "name": "expressjs-boilerplate",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "rimraf build && tsc",
    "start": "node build/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "db:migrate": "node ./node_modules/knex/bin/cli.js migrate:latest --knexfile ./knexfile.ts",
    "db:seed": "node ./node_modules/knex/bin/cli.js seed:run --knexfile ./knexfile.ts",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "make:migration": "node ./node_modules/knex/bin/cli.js migrate:make",
    "make:seed": "node ./node_modules/knex/bin/cli.js seed:make"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-useragent": "^2.2.0",
    "google-libphonenumber": "^3.2.44",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.3.0",
    "luxon": "^3.7.2",
    "mysql2": "^3.22.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-useragent": "^1.0.5",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
